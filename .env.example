# Core credentials
PJM_USERNAME=
PJM_PASSWORD=
PJM_CERT=
PJM_CERT_PASSWORD=

# Environment and backend
PJM_ENV=TRAIN
PJM_BACKEND=native

# Optional overrides
PJM_OASIS_URL=
PJM_SSO_URL=
PJM_CLI_DOWNLOADS=./downloads
PJM_TIMEOUT_SEC=30

# CLI backend only
PJM_CLI_JAR_PATH=
PJM_CLI_JAVA_PATH=

# Native backend PEM pair (alternative to PKCS#12)
PJM_CERT_PATH=
PJM_KEY_PATH=

# Live integration tests
PJM_LIVE_TEST=0
